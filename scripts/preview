#!/bin/bash
# preview — HTML 파일을 로컬 서버로 띄우고 브라우저에서 자동으로 열기
#
# Usage:
#   preview path/to/file.html          # 서버 시작 + 브라우저 오픈
#   preview path/to/file.html 9999     # 커스텀 포트
#   preview --stop                     # 실행 중인 프리뷰 서버 종료

set -e

PORT="${2:-8899}"
PID_FILE="/tmp/preview-server.pid"

# --stop: 기존 서버 종료
if [ "$1" = "--stop" ]; then
  if [ -f "$PID_FILE" ]; then
    kill "$(cat "$PID_FILE")" 2>/dev/null && echo "Preview server stopped." || echo "Server already stopped."
    rm -f "$PID_FILE"
  else
    echo "No preview server running."
  fi
  exit 0
fi

FILE="${1:?Usage: preview <file.html> [port]}"

if [ ! -f "$FILE" ]; then
  echo "Error: File not found: $FILE"
  exit 1
fi

# 절대 경로로 변환
ABS_PATH="$(cd "$(dirname "$FILE")" && pwd)/$(basename "$FILE")"
DIR="$(dirname "$ABS_PATH")"
BASENAME="$(basename "$ABS_PATH")"

# 기존 프리뷰 서버 종료
if [ -f "$PID_FILE" ]; then
  kill "$(cat "$PID_FILE")" 2>/dev/null || true
  rm -f "$PID_FILE"
fi

# 해당 포트 사용 중이면 종료
lsof -ti:"$PORT" 2>/dev/null | xargs kill 2>/dev/null || true

# Python HTTP 서버 백그라운드 실행
cd "$DIR"
python3 -m http.server "$PORT" --bind 127.0.0.1 > /dev/null 2>&1 &
SERVER_PID=$!
echo "$SERVER_PID" > "$PID_FILE"

# 서버 시작 대기
sleep 0.3

URL="http://localhost:$PORT/$BASENAME"

# 브라우저에서 열기
open "$URL"

echo "Preview: $URL (PID: $SERVER_PID)"
echo "Stop:    preview --stop"
